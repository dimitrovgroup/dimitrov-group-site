---
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';
import ActivityItem from '~/components/ActivityItem.astro';

// Only upcoming activities. Sorted by date desc (furthest-future first); change
// the comparator below if you'd rather see soonest-first.
const all = (await getCollection('activities', ({ data }) => !data.draft && data.status === 'upcoming'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const team       = all.filter((a) => a.data.kind === 'team-activity');
const congresses = all.filter((a) => a.data.kind === 'congress');
---

<Base title="Activities" description="Team activities and congress contributions from the Orthopaedic Research Group.">
  <section>
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">Activities</p>
        <h1>Where we are and what we're doing.</h1>
        <p class="lede">Team activities and congress contributions.</p>
      </header>

      <section class="act-group">
        <h2 class="act-group-h">Team activities</h2>
        {team.length > 0 ? (
          <div class="grid grid-2">
            {team.map((a) => <ActivityItem activity={a} />)}
          </div>
        ) : (
          <p class="muted">No upcoming team activities.</p>
        )}
      </section>

      <section class="act-group">
        <h2 class="act-group-h">Congresses</h2>
        {congresses.length > 0 ? (
          <div class="grid grid-2">
            {congresses.map((a) => <ActivityItem activity={a} />)}
          </div>
        ) : (
          <p class="muted">No upcoming congresses.</p>
        )}
      </section>
    </div>
  </section>
</Base>

<style>
  .act-group { margin-bottom: var(--space-6); }
  .act-group-h {
    font-size: var(--fs-micro);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-subtle);
    font-weight: 600;
    margin: 0 0 var(--space-3);
  }
</style>
