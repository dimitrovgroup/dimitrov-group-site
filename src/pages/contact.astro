---
import Base from '~/layouts/Base.astro';

const mapsUrl = 'https://www.google.com/maps/search/?api=1&query=USBALO+Boycho+Boychev+Sofia';
const email = 'contact@dimitrov-group.eu';
---

<Base title="Contact" description="Institutional contact details for the Orthopaedic Research Group at USBALO 'Prof. Boycho Boychev', Sofia.">
  <section>
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">Contact</p>
        <h1>Get in touch.</h1>
        <p class="lede">For collaborations, study enquiries, and academic correspondence.</p>
      </header>

      <div class="card contact-card">
        <div>
          <p class="eyebrow">Address</p>
          <address class="contact-address">
            Specialized University Hospital for Orthopaedics<br />
            &ldquo;Prof. Boycho Boychev&rdquo; &mdash; USBALO<br />
            Nikola Petkov Blvd 56<br />
            Gorna Banya, 1614 Sofia, Bulgaria
          </address>
        </div>

        <div class="contact-actions">
          <a class="btn btn-primary contact-email" href={`mailto:${email}`}>
            <span class="contact-email-text">{email}</span>
            <span aria-hidden="true" class="contact-email-arrow">&rarr;</span>
          </a>
          <a class="btn btn-ghost" href={mapsUrl} target="_blank" rel="noopener">
            Open in Maps <span aria-hidden="true">&#8599;</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-card {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .contact-address { font-style: normal; color: var(--text-muted); line-height: 1.6; }
  .contact-actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-3);
  }
  @media (min-width: 640px) {
    .contact-actions {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
    }
  }
  .contact-email {
    /* Sized to feel like a confident primary affordance. */
    justify-content: space-between;
    gap: var(--space-4);
    padding: 14px 22px;
    font-size: var(--fs-body);
    letter-spacing: -0.005em;
  }
  .contact-email-text { font-weight: 500; }
  .contact-email-arrow {
    transition: transform var(--dur) var(--ease);
    display: inline-block;
  }
  .contact-email:hover .contact-email-arrow { transform: translateX(3px); }
</style>
