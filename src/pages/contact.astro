---
import Base from '~/layouts/Base.astro';

// TODO: real address
const address = 'Orthopaedic Research Group, Sofia, Bulgaria';
const mapsUrl = `https://www.openstreetmap.org/search?query=${encodeURIComponent(address)}`;
---

<Base title="Contact" description="Institutional contact details for the Orthopaedic Research Group.">
  <section>
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">Contact</p>
        <h1>Get in touch.</h1>
        <p class="lede">For collaborations, study enquiries, and academic correspondence.</p>
      </header>

      <div class="card contact-card">
        <div>
          <p class="eyebrow">Address</p>
          <address class="contact-address">
            <!-- TODO: real address -->
            Orthopaedic Research Group<br />
            Sofia, Bulgaria
          </address>
        </div>

        <div>
          <p class="eyebrow">Email</p>
          <p><a class="text-link" href="mailto:contact@dimitrov-group.eu">contact@dimitrov-group.eu</a></p>
        </div>

        <div>
          <p class="eyebrow">Phone</p>
          <p class="muted">
            <!-- TODO: real phone number -->
            + TODO
          </p>
        </div>

        <div class="contact-actions row">
          <a class="btn btn-primary" href="mailto:contact@dimitrov-group.eu">Email the group</a>
          <a class="btn btn-ghost" href={mapsUrl} target="_blank" rel="noopener">
            Open in Maps <span aria-hidden="true">&#8599;</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-card {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .contact-address { font-style: normal; color: var(--text-muted); line-height: 1.55; }
  .contact-actions { gap: var(--space-3); margin-top: var(--space-2); }
</style>
