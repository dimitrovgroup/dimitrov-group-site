---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '~/layouts/Base.astro';
import Avatar from '~/components/Avatar.astro';
import PublicationItem from '~/components/PublicationItem.astro';
import ActivityItem from '~/components/ActivityItem.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import { getPublications } from '~/utils/publications.ts';
import { getMemberPubmedNames } from '~/utils/members.ts';

export async function getStaticPaths() {
  const members = await getCollection('members', ({ data }) => !data.draft);
  return members.map((member) => ({
    params: { slug: member.slug },
    props: { member },
  }));
}

type Props = { member: CollectionEntry<'members'> };
const { member } = Astro.props;
const d = member.data;
const { Content } = await member.render();

// Related publications.
const pubs = getPublications().filter((p) => p.members.includes(member.slug));

// PubMed-name map for highlighting member authors in citation lines.
const memberPubmedNames = await getMemberPubmedNames();
const allMembers = await getCollection('members');

// Congress presentations where this member is the presenter.
const allActivities = await getCollection('activities', ({ data }) => !data.draft);
const presentations = allActivities
  .filter((a) => a.data.kind === 'congress' && a.data.presentation?.presenter === member.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Projects.
const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const memberProjects = allProjects
  .filter((p) => p.data.members.includes(member.slug))
  .sort((a, b) => a.data.order - b.data.order);

// Collaborators.
const collaboratorEntries = (d.collaborators || [])
  .map((slug) => allMembers.find((m) => m.slug === slug))
  .filter((m): m is CollectionEntry<'members'> => Boolean(m));

const description = d.shortBio ?? `${d.name}, ${d.role}, Orthopaedic Research Group.`;
---

<Base title={d.name} description={description}>
  <section>
    <div class="container member-page">
      <header class="member-head">
        <Avatar
          name={d.name}
          initials={d.initials}
          src={d.portrait}
          srcWebp={d.portraitWebp}
          size={192}
          eager
          transitionName={`avatar-${member.slug}`}
        />
        <div class="member-head-text">
          <p class="eyebrow">{d.role}{d.external && ' · External collaborator'}</p>
          <h1>{d.name}</h1>
          {d.title && <p class="muted">{d.title}</p>}
          {d.affiliation && <p class="muted">{d.affiliation}</p>}
          {d.email && (
            <p>
              <a class="text-link" href={`mailto:${d.email}`}>{d.email}</a>
            </p>
          )}
        </div>
      </header>

      <article class="member-bio prose">
        <Content />
      </article>

      {d.interests.length > 0 && (
        <section class="member-section">
          <h2 class="member-h">Research interests</h2>
          <div class="row interests">
            {d.interests.map((i) => <span class="badge">{i}</span>)}
          </div>
        </section>
      )}

      {pubs.length > 0 && (
        <section class="member-section">
          <h2 class="member-h">Publications</h2>
          <div class="stack pubs-list">
            {pubs.map((p) => (
              <PublicationItem
                pub={p}
                memberPubmedNames={memberPubmedNames}
                highlightMember={member.slug}
              />
            ))}
          </div>
        </section>
      )}

      {presentations.length > 0 && (
        <section class="member-section">
          <h2 class="member-h">Presentations</h2>
          <div class="grid grid-2">
            {presentations.map((a) => <ActivityItem activity={a} />)}
          </div>
        </section>
      )}

      {memberProjects.length > 0 && (
        <section class="member-section">
          <h2 class="member-h">Projects</h2>
          <div class="grid grid-2">
            {memberProjects.map((p) => <ProjectCard project={p} />)}
          </div>
        </section>
      )}

      {collaboratorEntries.length > 0 && (
        <section class="member-section">
          <details class="collab-details">
            <summary>Collaborators ({collaboratorEntries.length})</summary>
            <ul class="collab-list">
              {collaboratorEntries.map((c) => (
                <li>
                  <a class="text-link" href={`/team/${c.slug}/`}>{c.data.name}</a>
                  <span class="subtle"> &middot; {c.data.role}</span>
                </li>
              ))}
            </ul>
          </details>
        </section>
      )}

      <p class="row" style="margin-top: var(--space-6);">
        <a class="btn btn-ghost" href="/team/"><span aria-hidden="true">&larr;</span> All team members</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .member-page { max-width: var(--container-narrow); }
  .member-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  @media (min-width: 640px) {
    .member-head { flex-direction: row; align-items: center; gap: var(--space-5); }
  }
  .member-head-text { display: flex; flex-direction: column; gap: var(--space-2); }
  .member-head-text h1 { font-size: var(--fs-h1); }
  .member-bio { margin-bottom: var(--space-6); }
  .prose p { margin: 0 0 1em; }
  .member-section { margin-top: var(--space-6); }
  .member-h {
    font-size: var(--fs-micro);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-subtle);
    font-weight: 600;
    margin: 0 0 var(--space-3);
  }
  .interests { gap: var(--space-2); }
  .collab-details {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
  }
  .collab-details summary {
    cursor: pointer;
    font-weight: 500;
    list-style: none;
    min-height: 44px;
    display: flex;
    align-items: center;
  }
  .collab-details summary::-webkit-details-marker { display: none; }
  .collab-details[open] summary { margin-bottom: var(--space-3); }
  .collab-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }
</style>
