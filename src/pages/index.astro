---
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';
import Hero from '~/components/Hero.astro';
import Section from '~/components/Section.astro';
import Reveal from '~/components/Reveal.astro';
import MemberCard from '~/components/MemberCard.astro';
import PublicationItem from '~/components/PublicationItem.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import ActivityItem from '~/components/ActivityItem.astro';
import { getPublications } from '~/utils/publications.ts';
import { getMemberPubmedNames } from '~/utils/members.ts';

// Members, sorted by `order`.
const members = (await getCollection('members', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const pi = members.find((m) => m.slug === 'n-dimitrov');
const others = members.filter((m) => m.slug !== 'n-dimitrov');
const PiContent = pi ? (await pi.render()).Content : null;

// Recent publications.
const pubs = getPublications().slice(0, 5);
const memberPubmedNames = await getMemberPubmedNames();

// Active projects.
const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .filter((p) => p.data.status === 'Ongoing' || p.data.status === 'Recruiting')
  .sort((a, b) => a.data.order - b.data.order);

// Recent activities.
const activities = (await getCollection('activities', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const researchLines = [
  {
    title: 'Arthroplasty',
    blurb: 'Prospective outcomes after primary and revision hip and knee arthroplasty.',
  },
  {
    title: 'Arthroscopy',
    blurb:
      'Outcomes of arthroscopic procedures across joints, with structured pre- and post-operative measurement.',
  },
  {
    title: 'Registry science',
    blurb: 'Methodology and governance of prospective clinical registries in orthopaedics.',
  },
  {
    title: 'Interdisciplinary studies',
    blurb:
      'Collaborative research at the intersection of orthopaedics and adjacent specialties: psychiatry, rehabilitation, and beyond.',
  },
];

const description =
  'Clinical research in orthopaedics and traumatology, led by Prof. N. Dimitrov. Prospective studies, patient-reported outcomes, and open publication.';
---

<Base title="Home" description={description}>
  <Hero />

  <Reveal>
    <Section
      id="about"
      eyebrow="About"
      title="What we study."
      lede="Our focus lies in orthopaedic outcome studies and their effects in interdisciplinary settings."
    >
      <div class="grid grid-4">
        {researchLines.map((r) => (
          <article class="card">
            <h3>{r.title}</h3>
            <p class="muted" style="margin-top: var(--space-2); font-size: var(--fs-small);">{r.blurb}</p>
          </article>
        ))}
      </div>
    </Section>
  </Reveal>

  <Reveal>
    <Section id="team" eyebrow="Team" title="The people." lede="A focused group, with external collaborators where they bring expertise.">
      {pi && PiContent && (
        <div class="pi-grid pi-spotlight-nested">
          <figure class="pi-portrait">
            <picture>
              {pi.data.portraitWebp && <source srcset={pi.data.portraitWebp} type="image/webp" />}
              {pi.data.portrait && (
                <img
                  src={pi.data.portrait}
                  alt={`Portrait of ${pi.data.name}`}
                  width="720"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </picture>
          </figure>
          <div class="pi-body">
            <p class="eyebrow">Principal Investigator</p>
            <h2 class="pi-name">{pi.data.name}</h2>
            <div class="pi-bio prose">
              <PiContent />
            </div>
            {pi.data.interests.length > 0 && (
              <div class="pi-tags row">
                {pi.data.interests.map((tag) => (
                  <span class="pi-tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      )}

      <div class="grid grid-3 team-grid">
        {others.map((m) => <MemberCard member={m} />)}
      </div>
      <p class="row team-cta">
        <a class="btn btn-ghost" href="/team/">All team members</a>
      </p>
    </Section>
  </Reveal>

  <Reveal>
    <Section
      id="publications"
      eyebrow="Publications"
      title="Recent work."
      lede="Our latest PubMed-indexed papers."
    >
      <div class="stack pubs-list">
        {pubs.map((p) => <PublicationItem pub={p} memberPubmedNames={memberPubmedNames} />)}
      </div>
      <p class="row team-cta">
        <a class="btn btn-ghost" href="/publications/">All publications</a>
      </p>
    </Section>
  </Reveal>

  <Reveal>
    <Section
      id="projects"
      eyebrow="Projects"
      title="Active studies."
      lede="Active prospective studies."
    >
      <div class="grid grid-2">
        {projects.map((p) => <ProjectCard project={p} />)}
      </div>
      <p class="row team-cta">
        <a class="btn btn-ghost" href="/projects/">All projects</a>
      </p>
    </Section>
  </Reveal>

  <Reveal>
    <Section id="activities" eyebrow="Activities" title="Where we'll be." lede="Recent team activities and upcoming congresses.">
      <div class="grid grid-3">
        {activities.map((a) => <ActivityItem activity={a} />)}
      </div>
      <p class="row team-cta">
        <a class="btn btn-ghost" href="/activities/">All activities</a>
      </p>
    </Section>
  </Reveal>

  <Reveal>
    <Section id="contact" eyebrow="Contact" title="Get in touch." lede="For collaborations, study enquiries, and academic correspondence.">
      <div class="card contact-card">
        <address class="contact-address">
          Specialized University Hospital for Orthopaedics<br />
          &ldquo;Prof. Boycho Boychev&rdquo;, USBALO<br />
          Nikola Petkov Blvd 56<br />
          Gorna Banya, 1614 Sofia, Bulgaria
        </address>
        <div class="contact-links">
          <a class="btn btn-primary contact-email" href="mailto:contact@dimitrov-group.eu">
            <span class="contact-email-text">contact@dimitrov-group.eu</span>
            <span aria-hidden="true" class="contact-email-arrow">&rarr;</span>
          </a>
          <a class="btn btn-ghost" href="/contact/">Contact details</a>
        </div>
      </div>
    </Section>
  </Reveal>
</Base>

<style>
  .about-body { max-width: 65ch; }
  .team-grid { margin-top: var(--space-5); }

  /* PI spotlight (nested inside Team section, under the section header). */
  .pi-spotlight-nested {
    margin-bottom: var(--space-7);
  }
  @media (min-width: 768px) {
    .pi-spotlight-nested { margin-bottom: var(--space-8); }
  }
  /* Two columns at every breakpoint — small mobile portrait compensates
     for the low-resolution Dimitrov source image. Portrait sits at the TOP
     of the row (align-items: start) so the eyebrow + name line up next to it. */
  .pi-grid {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 120px 1fr;
    align-items: start;
  }
  @media (min-width: 768px) {
    .pi-grid {
      grid-template-columns: 220px 1fr;
      gap: var(--space-5);
    }
  }
  @media (min-width: 1024px) {
    .pi-grid {
      grid-template-columns: minmax(280px, 320px) 1fr;
      gap: var(--space-7);
      align-items: center; /* desktop: portrait and text are similar height — center looks balanced */
    }
  }
  /* Very narrow screens only (older small phones): fall back to stacked. */
  @media (max-width: 339px) {
    .pi-grid { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  .pi-portrait {
    margin: 0;
    aspect-ratio: 4 / 5;
    background: var(--surface);
    overflow: hidden;
    /* Mobile: round, reads as a large avatar. */
    border-radius: 50%;
    aspect-ratio: 1 / 1;
    box-shadow: var(--shadow-md);
  }
  @media (min-width: 768px) {
    .pi-portrait {
      /* Tablet+: rounded rectangle, full portrait crop. */
      aspect-ratio: 4 / 5;
      border-radius: var(--radius-lg);
    }
  }
  .pi-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top; /* keep the face visible in the crop */
    display: block;
  }
  .pi-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  @media (min-width: 768px) {
    .pi-body { gap: var(--space-3); }
  }
  .pi-name {
    /* Smaller on mobile so it fits next to the 120px portrait. */
    font-size: clamp(1.25rem, 2.5vw + 0.5rem, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0;
  }
  .pi-bio {
    margin: var(--space-2) 0 0;
    font-size: var(--fs-small);
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 60ch;
  }
  @media (min-width: 768px) {
    .pi-bio { font-size: var(--fs-body); line-height: 1.6; }
  }
  .pi-bio :global(p) { margin: 0 0 0.8em; }
  .pi-bio :global(p:last-child) { margin-bottom: 0; }
  .pi-tags {
    margin-top: var(--space-2);
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .pi-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    color: var(--accent-ink);
    font-size: var(--fs-micro);
    font-weight: 500;
    letter-spacing: -0.005em;
  }

  .team-cta { margin-top: var(--space-5); }
  .pubs-list { gap: var(--space-2); }

  .contact-card {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .contact-address {
    font-style: normal;
    color: var(--text-muted);
    line-height: 1.55;
  }
  .contact-links {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  @media (min-width: 640px) {
    .contact-links {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
    }
  }
  .contact-email {
    justify-content: space-between;
    gap: var(--space-4);
    padding: 14px 22px;
    font-size: var(--fs-body);
    letter-spacing: -0.005em;
  }
  .contact-email-text { font-weight: 500; }
  .contact-email-arrow {
    transition: transform var(--dur) var(--ease);
    display: inline-block;
  }
  .contact-email:hover .contact-email-arrow { transform: translateX(3px); }
</style>
