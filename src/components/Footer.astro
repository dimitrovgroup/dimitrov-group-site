---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-col">
      <div class="wordmark">
        <span class="wordmark-name">Orthopaedic Research Group</span>
        <span class="wordmark-dot" aria-hidden="true"></span>
        <span class="wordmark-pi">Prof. N. Dimitrov</span>
      </div>
      <p class="muted footer-tag">Clinical research in orthopaedics and traumatology.</p>
      <p class="subtle footer-copy">&copy; {year} Dimitrov Group</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-soft);
    padding-block: var(--space-7);
    margin-top: var(--space-8);
  }
  .footer-inner {
    display: flex;
  }
  .footer-col { display: flex; flex-direction: column; gap: var(--space-3); }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 600;
    font-size: var(--fs-small);
  }
  .wordmark-dot {
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--accent);
  }
  .wordmark-pi {
    color: var(--text-muted);
    font-weight: 500;
    font-size: var(--fs-micro);
  }
  .footer-tag { margin: 0; max-width: 40ch; font-size: var(--fs-small); }
  .footer-copy { margin: 0; font-size: var(--fs-micro); }
</style>
