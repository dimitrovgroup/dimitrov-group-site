---
type Props = {
  name: string;
  initials?: string;
  src?: string;     // JPG path under /public, e.g. "/team/n-dimitrov.jpg"
  srcWebp?: string; // WebP path under /public, e.g. "/team/n-dimitrov.webp"
  size?: number;
  eager?: boolean;  // set true for above-the-fold avatars; otherwise lazy
  transitionName?: string; // for Astro View Transitions (morphing avatar between pages)
};

const { name, initials: explicitInitials, src, srcWebp, size = 96, eager = false, transitionName } = Astro.props;

/**
 * Robust fallback monogram. Strips honorifics ("Professor"/"Prof", "Dr"/"Doctor",
 * "PhD", "MD", "Mr/Mrs/Ms") with optional trailing dot, then strips
 * punctuation, then takes the first letter of the first surviving token
 * and the first letter of the last surviving token.
 */
function deriveInitials(n: string): string {
  const stripped = n.replace(/\b(Professor|Prof|Doctor|Dr|PhD|MD|Mr|Mrs|Ms)\.?/gi, '');
  const clean = stripped.replace(/[,;]+/g, ' ').replace(/\s+/g, ' ').trim();
  const parts = clean.split(/\s+/).filter(Boolean);
  if (parts.length === 0) return '?';
  const firstClean = parts[0].replace(/[^\p{L}]/gu, '');
  const lastClean  = parts.length > 1
    ? parts[parts.length - 1].replace(/[^\p{L}]/gu, '')
    : '';
  const first = firstClean[0] ?? '';
  const last  = lastClean[0]  ?? '';
  return (first + last).toUpperCase() || '?';
}

const mono = (explicitInitials ?? '').trim() || deriveInitials(name);
const sizePx = `${size}px`;
const fontPx = `${Math.round(size * 0.36)}px`;
const loading = eager ? 'eager' : 'lazy';
---

<div
  class="avatar"
  style={`--avatar-size: ${sizePx}; --avatar-font: ${fontPx};`}
  {...(transitionName ? { 'transition:name': transitionName } : {})}
>
  {src ? (
    <picture>
      {srcWebp && <source srcset={srcWebp} type="image/webp" />}
      <img
        src={src}
        alt={`Portrait of ${name}`}
        width={size}
        height={size}
        loading={loading}
        decoding="async"
        class="avatar-img"
      />
    </picture>
  ) : (
    <>
      <span class="avatar-mono" aria-hidden="true">{mono}</span>
      <span class="visually-hidden">{name}</span>
    </>
  )}
</div>

<style>
  .avatar {
    width: var(--avatar-size);
    height: var(--avatar-size);
    border-radius: 50%;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--accent-soft);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }
  .avatar picture { display: block; width: 100%; height: 100%; }
  .avatar-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top; /* faces tend to sit in the top-center of 4:5 portraits */
  }
  .avatar-mono {
    color: var(--accent-ink);
    font-weight: 600;
    font-size: var(--avatar-font);
    letter-spacing: -0.02em;
    line-height: 1;
  }
</style>
