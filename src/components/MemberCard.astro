---
import type { CollectionEntry } from 'astro:content';
import Avatar from './Avatar.astro';

type Props = {
  member: CollectionEntry<'members'>;
  variant?: 'default' | 'spotlight';
};

const { member, variant = 'default' } = Astro.props;
const d = member.data;
---

<article class={`card card-hover member-card reveal ${variant === 'spotlight' ? 'is-spotlight' : ''}`}>
  <div class="member-card-inner">
    <Avatar
      name={d.name}
      initials={d.initials}
      src={d.portrait}
      srcWebp={d.portraitWebp}
      size={variant === 'spotlight' ? 128 : 96}
      transitionName={`avatar-${member.slug}`}
    />
    <div class="member-card-body">
      <div class="member-card-head">
        <h3>{d.name}</h3>
        {d.external && <span class="badge">Collaborator</span>}
      </div>
      {!d.external && <p class="eyebrow">{d.role}</p>}
      {d.shortBio && <p class="muted member-card-bio">{d.shortBio}</p>}
    </div>
  </div>
</article>

<style>
  .member-card-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .is-spotlight .member-card-inner {
    flex-direction: column;
  }
  @media (min-width: 768px) {
    .is-spotlight .member-card-inner {
      flex-direction: row;
      align-items: center;
      gap: var(--space-5);
    }
  }
  .member-card-body { display: flex; flex-direction: column; gap: var(--space-2); flex: 1; }
  .member-card-head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .member-card-bio { margin: 0; font-size: var(--fs-small); }
</style>
