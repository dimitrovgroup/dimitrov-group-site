---
import type { CollectionEntry } from 'astro:content';
import Avatar from './Avatar.astro';

type Props = {
  member: CollectionEntry<'members'>;
  variant?: 'default' | 'spotlight';
};

const { member, variant = 'default' } = Astro.props;
const d = member.data;
const href = `/team/${member.slug}/`;
---

<article class={`card card-hover member-card ${variant === 'spotlight' ? 'is-spotlight' : ''}`}>
  <div class="member-card-inner">
    <Avatar name={d.name} initials={d.initials} src={d.portrait} size={variant === 'spotlight' ? 128 : 96} />
    <div class="member-card-body">
      <div class="member-card-head">
        <h3>{d.name}</h3>
        {d.external && <span class="badge">Collaborator</span>}
      </div>
      <p class="eyebrow">{d.role}</p>
      {d.shortBio && <p class="muted member-card-bio">{d.shortBio}</p>}
      <a class="member-card-link" href={href} aria-label={`View profile of ${d.name}`}>
        Profile <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</article>

<style>
  .member-card-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .is-spotlight .member-card-inner {
    flex-direction: column;
  }
  @media (min-width: 768px) {
    .is-spotlight .member-card-inner {
      flex-direction: row;
      align-items: center;
      gap: var(--space-5);
    }
  }
  .member-card-body { display: flex; flex-direction: column; gap: var(--space-2); flex: 1; }
  .member-card-head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .member-card-bio { margin: 0; font-size: var(--fs-small); }
  .member-card-link {
    margin-top: var(--space-2);
    color: var(--accent-ink);
    font-weight: 500;
    font-size: var(--fs-small);
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: gap var(--dur) var(--ease);
    gap: 6px;
  }
  .member-card-link:hover { gap: 10px; }
</style>
