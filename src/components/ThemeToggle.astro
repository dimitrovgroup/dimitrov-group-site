---
// Theme toggle. Light/dark, persisted to localStorage as 'theme'.
// If the user has never toggled, the inline bootstrap in Base.astro
// follows the system preference.
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  aria-pressed="false"
>
  <svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <line x1="12" y1="2"  x2="12" y2="4"></line>
    <line x1="12" y1="20" x2="12" y2="22"></line>
    <line x1="2"  y1="12" x2="4"  y2="12"></line>
    <line x1="20" y1="12" x2="22" y2="12"></line>
    <line x1="4.93"  y1="4.93"  x2="6.34"  y2="6.34"></line>
    <line x1="17.66" y1="17.66" x2="19.07" y2="19.07"></line>
    <line x1="4.93"  y1="19.07" x2="6.34"  y2="17.66"></line>
    <line x1="17.66" y1="6.34"  x2="19.07" y2="4.93"></line>
  </svg>
  <svg class="icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-pill);
    color: var(--text);
    transition: background-color 180ms ease-out, color 180ms ease-out;
  }
  .theme-toggle:hover { background: var(--surface); }
  /* Stack both icons; crossfade between them on theme change. */
  .icon {
    width: 20px; height: 20px;
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%) rotate(0deg);
    transition: opacity 200ms ease-out, transform 200ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .icon-sun  { opacity: 1; }
  .icon-moon { opacity: 0; transform: translate(-50%, -50%) rotate(-30deg); }
  :root[data-theme='dark'] .icon-sun  { opacity: 0; transform: translate(-50%, -50%) rotate(30deg); }
  :root[data-theme='dark'] .icon-moon { opacity: 1; transform: translate(-50%, -50%) rotate(0deg); }

  @media (prefers-reduced-motion: reduce) {
    .icon { transition: none; transform: translate(-50%, -50%); }
    :root[data-theme='dark'] .icon-sun,
    :root[data-theme='dark'] .icon-moon { transform: translate(-50%, -50%); }
  }
</style>

<script>
  // The Nav (and this button inside it) is `transition:persist`-ed across
  // Astro view transitions, but hoisted scripts re-execute on every
  // navigation. Without this guard we'd attach the click listener N times
  // and each click would toggle the theme N times — appearing "broken".
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.themeToggleReady === '1') return;
    btn.dataset.themeToggleReady = '1';
    const setPressed = () => {
      const t = document.documentElement.getAttribute('data-theme');
      btn.setAttribute('aria-pressed', t === 'dark' ? 'true' : 'false');
    };
    setPressed();
    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (_e) { /* ignore */ }
      setPressed();
    });
  }
  initThemeToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
</script>
