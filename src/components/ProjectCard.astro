---
import { getCollection, type CollectionEntry } from 'astro:content';

type Props = { project: CollectionEntry<'projects'> };
const { project } = Astro.props;
const d = project.data;

const yearRange = d.endYear ? `${d.startYear}-${d.endYear}` : `${d.startYear}-present`;
const statusClass = `badge-${d.status.toLowerCase()}`;

// Resolve the lead member's display name (if a leadMember slug is set).
let leadName: string | null = null;
if (d.leadMember) {
  const members = await getCollection('members');
  const lead = members.find((m) => m.slug === d.leadMember);
  if (lead) leadName = lead.data.name;
}
---

<article class="card card-hover project-card reveal">
  <div class="project-head">
    <span class={`badge ${statusClass}`}>{d.status}</span>
    <span class="subtle project-years">{yearRange}</span>
  </div>
  <h3 class="project-title">{d.title}</h3>
  <p class="muted project-summary">{d.summary}</p>

  {leadName && (
    <p class="project-lead subtle">Lead: {leadName}</p>
  )}

  {d.registry && (
    <footer class="project-foot row">
      <a
        class="project-registry"
        href={
          d.registry.name === 'ClinicalTrials.gov'
            ? `https://clinicaltrials.gov/study/${d.registry.id}`
            : `https://www.google.com/search?q=${encodeURIComponent(`${d.registry.name} ${d.registry.id}`)}`
        }
        target="_blank"
        rel="noopener"
      >
        {d.registry.name}: {d.registry.id} <span aria-hidden="true">&#8599;</span>
      </a>
    </footer>
  )}
</article>

<style>
  .project-card { display: flex; flex-direction: column; gap: var(--space-3); height: 100%; }
  .project-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .project-years { font-size: var(--fs-micro); }
  .project-title { margin: 0; }
  .project-summary { margin: 0; font-size: var(--fs-small); }
  .project-lead {
    margin: 0;
    font-size: var(--fs-micro);
  }
  .project-foot {
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--border);
    font-size: var(--fs-micro);
    gap: var(--space-4);
  }
  .project-registry {
    color: var(--accent-ink);
    font-weight: 500;
  }
  .project-registry:hover { text-decoration: underline; }
</style>
