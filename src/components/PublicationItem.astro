---
import type { Publication } from '~/utils/publications.ts';
import { pubmedUrl, doiUrl } from '~/utils/links.ts';

type Props = {
  pub: Publication;
  /** A member slug whose author entry should be visually emphasised. */
  highlightMember?: string;
  /** Optional map of member slug -> last name (e.g. "Dimitrov") for highlighting. */
  memberLastNames?: Record<string, string>;
};

const { pub, highlightMember, memberLastNames = {} } = Astro.props;

const pm = pub.pmid ? pubmedUrl(pub.pmid) : '';
const di = pub.doi  ? doiUrl(pub.doi)    : '';

// Pre-render data-search-text for SearchBox filtering.
const searchText = `${pub.title} ${pub.authors.join(' ')} ${pub.journal} ${pub.year}`.toLowerCase();
const dataMembers = pub.members.join(',');

const highlightName =
  highlightMember && memberLastNames[highlightMember]
    ? memberLastNames[highlightMember].toLowerCase()
    : null;

function authorIsHighlighted(author: string): boolean {
  if (!highlightName) return false;
  return author.toLowerCase().includes(highlightName);
}
---

<article
  class={`pub ${pub.seniorAuthor ? 'is-senior' : ''}`}
  data-search-text={searchText}
  data-year={pub.year}
  data-members={dataMembers}
>
  <div class="pub-title-wrap">
    {pub.seniorAuthor && <span class="pub-senior-bar" aria-hidden="true"></span>}
    <h3 class="pub-title">{pub.title}</h3>
  </div>

  {pub.seniorAuthor && (
    <p class="pub-badges">
      <span class="badge badge-accent">Senior author</span>
    </p>
  )}

  <p class="pub-authors">
    {pub.authors.map((a, i) => (
      <>
        <span class={authorIsHighlighted(a) ? 'pub-author is-me' : 'pub-author'}>{a}</span>
        {i < pub.authors.length - 1 && <span class="pub-sep">, </span>}
      </>
    ))}
  </p>

  <p class="pub-meta subtle">
    <span class="pub-journal">{pub.journal}</span>
    <span aria-hidden="true"> &middot; </span>
    <span>{pub.year}</span>
  </p>

  {(pm || di) && (
    <div class="pub-links row">
      {pm && (
        <a class="pub-link" href={pm} target="_blank" rel="noopener">
          PubMed <span aria-hidden="true">&#8599;</span>
        </a>
      )}
      {di && (
        <a class="pub-link" href={di} target="_blank" rel="noopener">
          DOI <span aria-hidden="true">&#8599;</span>
        </a>
      )}
    </div>
  )}
</article>

<style>
  .pub {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    transition: background-color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .pub:hover {
    background: var(--surface);
    border-color: var(--border);
  }
  .pub-title-wrap {
    display: flex;
    align-items: stretch;
    gap: var(--space-3);
  }
  .pub-senior-bar {
    width: 4px;
    border-radius: 2px;
    background: var(--accent);
    flex-shrink: 0;
  }
  .pub-title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    margin: 0;
  }
  .pub-badges { margin: var(--space-2) 0 0; }
  .pub-authors {
    margin: var(--space-2) 0 0;
    font-size: var(--fs-small);
    color: var(--text-muted);
    line-height: 1.5;
  }
  .pub-author.is-me {
    color: var(--accent-ink);
    font-weight: 600;
  }
  .pub-meta {
    margin: var(--space-1) 0 0;
    font-size: var(--fs-micro);
  }
  .pub-journal { font-style: italic; }
  .pub-links {
    margin-top: var(--space-3);
    gap: var(--space-3);
  }
  .pub-link {
    color: var(--accent-ink);
    font-size: var(--fs-small);
    font-weight: 500;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: opacity var(--dur) var(--ease);
  }
  .pub-link:hover { opacity: 0.7; }
</style>
