---
import type { Publication } from '~/utils/publications.ts';
import { pubmedUrl, doiUrl } from '~/utils/links.ts';

type Props = {
  pub: Publication;
  /** Map of member slug → PubMed-style name (e.g. "Dimitrov N"). Used to bold any
   *  author who is a member of the group. */
  memberPubmedNames?: Record<string, string>;
  /** A member slug whose author entry should be visually emphasised (teal + bold).
   *  Used on per-member profile pages to highlight "you". */
  highlightMember?: string;
};

const { pub, memberPubmedNames = {}, highlightMember } = Astro.props;

const pm = pub.pmid ? pubmedUrl(pub.pmid) : '';
const di = pub.doi  ? doiUrl(pub.doi)    : '';

// Pre-render data-search-text for filtering.
const searchText = `${pub.title} ${pub.authors.join(' ')} ${pub.journal} ${pub.year}`.toLowerCase();
const dataMembers = pub.members.join(',');

const highlightPattern =
  highlightMember && memberPubmedNames[highlightMember]
    ? memberPubmedNames[highlightMember]
    : null;

/** True iff `author` matches `pattern` as a PubMed-style name, allowing for
 *  trailing additional initials (so "Adolf J" matches both "Adolf J" and "Adolf JA"). */
function matches(author: string, pattern: string): boolean {
  if (author === pattern) return true;
  if (author.startsWith(pattern)) {
    const next = author[pattern.length];
    return next === undefined || /[A-Z]/.test(next);
  }
  return false;
}

function authorIsMember(author: string): boolean {
  for (const pattern of Object.values(memberPubmedNames)) {
    if (matches(author, pattern)) return true;
  }
  return false;
}

function authorIsHighlight(author: string): boolean {
  return highlightPattern ? matches(author, highlightPattern) : false;
}
---

<article
  class="pub"
  data-search-text={searchText}
  data-year={pub.year}
  data-members={dataMembers}
>
  <h3 class="pub-title">{pub.title}</h3>

  <p class="pub-authors">
    {pub.authors.map((a, i) => {
      const isMe = authorIsHighlight(a);
      const isMember = authorIsMember(a);
      const isLast = i === pub.authors.length - 1;
      const cls = `pub-author${isMe ? ' is-me' : isMember ? ' is-member' : ''}${isLast ? ' is-last' : ''}`;
      return <span class={cls}>{a}</span>;
    })}
  </p>

  <p class="pub-meta subtle">
    <span class="pub-journal">{pub.journal}</span>
    <span aria-hidden="true"> &middot; </span>
    <span>{pub.year}</span>
  </p>

  {(pm || di) && (
    <div class="pub-links row">
      {pm && (
        <a class="pub-link" href={pm} target="_blank" rel="noopener">
          PubMed <span aria-hidden="true">&#8599;</span>
        </a>
      )}
      {di && (
        <a class="pub-link" href={di} target="_blank" rel="noopener">
          DOI <span aria-hidden="true">&#8599;</span>
        </a>
      )}
    </div>
  )}
</article>

<style>
  .pub {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    transition: background-color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .pub:hover {
    background: var(--surface);
    border-color: var(--border);
  }
  .pub-title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    margin: 0;
  }
  .pub-authors {
    margin: var(--space-2) 0 0;
    font-size: var(--fs-small);
    color: var(--text-muted);
    line-height: 1.5;
  }
  .pub-author { display: inline; }
  .pub-author:not(.is-last)::after {
    content: ', ';
    color: var(--text-muted);
    font-weight: 400;
  }
  .pub-author.is-member {
    color: var(--text);
    font-weight: 600;
  }
  .pub-author.is-me {
    color: var(--accent-ink);
    font-weight: 600;
  }
  .pub-meta {
    margin: var(--space-1) 0 0;
    font-size: var(--fs-micro);
  }
  .pub-journal { font-style: italic; }
  .pub-links {
    margin-top: var(--space-3);
    gap: var(--space-3);
  }
  .pub-link {
    color: var(--accent-ink);
    font-size: var(--fs-small);
    font-weight: 500;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: opacity var(--dur) var(--ease);
  }
  .pub-link:hover { opacity: 0.7; }
</style>
