---
// Typographic hero. Centred vertically, generous whitespace.
---

<section class="hero">
  <div class="container hero-inner">
    <p class="eyebrow hero-eyebrow">Clinical Research &middot; Orthopaedics &amp; Traumatology</p>
    <h1 class="hero-title">Orthopaedic Research Group</h1>
    <p class="hero-pi muted">Professor N. Dimitrov, MD, PhD</p>

    <p class="lede hero-lede">
      Clinical research in orthopaedics and traumatology.
    </p>

    <div class="hero-actions row">
      <a class="btn btn-primary" href="/#about">Our research</a>
      <a class="btn btn-ghost"   href="/#team">Meet the team</a>
    </div>

    <span class="hero-rule" aria-hidden="true"></span>
  </div>
</section>

<style>
  .hero {
    min-height: 85vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-9);
  }
  @media (min-width: 768px) {
    .hero { padding-inline: var(--space-3); }
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 1080px;
  }

  /* The group name dominates. */
  .hero-title {
    font-size: clamp(2.75rem, 7.5vw, 5.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.02;
    margin: 0;
    color: var(--text);
    /* Allow natural wrapping; the container caps width so it breaks
       to a second line on tablet, stays single line on wide desktop. */
    max-width: 14ch;
  }
  @media (min-width: 1024px) {
    .hero-title { max-width: none; }
  }

  /* Everything else recedes. */
  .hero-pi {
    font-size: var(--fs-lede);
    letter-spacing: -0.01em;
    margin: 0;
  }
  .hero-lede {
    margin-top: var(--space-2);
    max-width: 56ch;
  }
  .hero-actions {
    margin-top: var(--space-4);
    gap: var(--space-3);
  }
  .hero-rule {
    display: block;
    width: 64px;
    height: 1px;
    background: var(--accent);
    margin-top: var(--space-7);
    opacity: 0.7;
  }

  /* Staggered fade-in on page load. */
  .hero-eyebrow,
  .hero-title,
  .hero-pi,
  .hero-lede,
  .hero-actions,
  .hero-rule {
    opacity: 0;
    transform: translateY(8px);
    animation: heroFadeIn 600ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-eyebrow { animation-delay:   0ms; }
  .hero-title   { animation-delay: 100ms; }
  .hero-pi      { animation-delay: 220ms; }
  .hero-lede    { animation-delay: 340ms; }
  .hero-actions { animation-delay: 460ms; }
  .hero-rule    { animation-delay: 580ms; }

  @keyframes heroFadeIn {
    to { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow,
    .hero-title,
    .hero-pi,
    .hero-lede,
    .hero-actions,
    .hero-rule {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
